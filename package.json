{
  "name": "factcheck-ai-media-analyzer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "test": "vitest run --config test/vitest.config.ts",
    "test:watch": "vitest --config test/vitest.config.ts",
    "test:e2e": "playwright test --config test/e2e-browser/playwright.config.ts",
    "test:e2e:auth": "playwright test auth-setup.spec.ts --config=test/e2e-browser/playwright.video-analysis.config.ts --headed",
    "test:e2e:video": "playwright test video-deep-analysis-stability.spec.ts --config=test/e2e-browser/playwright.video-analysis.config.ts",
    "test:lighthouse": "npm run build && lhci autorun --config=lighthouserc.cjs"
  },
  "dependencies": {
    "@google/genai": "^1.38.0",
    "better-sqlite3": "^12.4.1",
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@mozilla/readability": "^0.6.0",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.7.0",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "framer-motion": "^12.34.3",
    "motion": "^12.23.24",
    "html2canvas": "^1.4.1",
    "http-proxy-middleware": "^3.0.5",
    "i18next": "^25.8.13",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.575.0",
    "multer": "^2.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-helmet-async": "^2.0.5",
    "react-markdown": "^10.1.0",
    "react-i18next": "^16.5.4",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "recharts": "^3.6.0",
    "tailwind-merge": "^3.5.0",
    "youtube-transcript": "^1.2.1"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
